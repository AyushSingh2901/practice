pipeline {
    agent any

    stages {
        

        stage('Docker Build') {
            steps {
                sh 'docker build -t practice .'
            }
        }
        stage('Docker Run') {
            steps {
                sh 'docker rm -f practice-container || true'
                sh 'docker run -d --name practice-container -p 2929:2929 practice'
            }
        }
           
        
    }
}